{
  "$schema": "https://anthropic.com/claude-code/mcp.schema.json",
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/damools/business",
        "/home/damools/mywsl_workspace/portfolio-project"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "nanobanana": {
      "command": "npx",
      "args": ["-y", "nanobanana-api-mcp"],
      "description": "Google Gemini AI image generation/editing (Tier 3 — requires GOOGLE_API_KEY)"
    }
  }
}
