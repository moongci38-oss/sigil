# === MCP Server API Keys ===
# Context7 (https://context7.com/)
CONTEXT7_API_KEY=your_context7_api_key_here

# === Workspace Paths (팀원별 설정) ===
# Business 워크스페이스 루트 (절대경로)
BUSINESS_ROOT=/path/to/your/business

# Portfolio 프로젝트 루트 (절대경로)
PORTFOLIO_PROJECT=/path/to/your/portfolio-project

# === Agent Teams (선택 — Competing Hypotheses/Watchdog 전용) ===
# 일반 병렬 작업은 Subagent로 동작하므로 이 변수는 불필요
# Agent Teams가 필요한 경우에만 활성화 (tmux 필수)
# CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1

# === YouTube Data API v3 (yt-analyzer 검색/재생목록용) ===
# 발급: https://console.cloud.google.com/apis/credentials
# 1. 프로젝트 생성 → YouTube Data API v3 활성화 → API 키 생성
# 2. 이 파일을 .env로 복사 후 키 입력
# YOUTUBE_API_KEY=AIza...
