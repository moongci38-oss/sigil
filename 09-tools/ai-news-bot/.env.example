# Telegram Bot 설정
# BotFather(@BotFather)에서 발급받은 봇 토큰
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ

# 메시지를 받을 채팅 ID
# 개인 채팅: @userinfobot에 /start 보내서 확인
# 그룹: 봇을 그룹에 추가 후 https://api.telegram.org/bot<TOKEN>/getUpdates 에서 확인
TELEGRAM_CHAT_ID=123456789

# 아카이브 저장 경로 (선택 — 기본값: ../../01-research/weekly/)
# ARCHIVE_DIR=/path/to/01-research/weekly
