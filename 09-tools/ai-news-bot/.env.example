# ── Notion 설정 (기본 발송 채널) ──────────────────────
# 1. https://www.notion.so/profile/integrations 에서 Internal Integration 생성
# 2. 발급받은 토큰을 아래에 입력
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# 3. `python main.py --setup-db` 실행 후 출력되는 ID를 입력
#    또는 기존 데이터베이스 URL에서 ID 복사
NOTION_DATABASE_ID=

# 4. DB 자동 생성 시 상위 페이지 ID (--setup-db 용)
#    Notion 페이지 URL: https://notion.so/My-Page-{이 부분이 ID}
#    ⚠️ Integration이 해당 페이지에 연결(Connection)되어 있어야 합니다
NOTION_PARENT_PAGE_ID=

# ── Telegram 설정 (선택 — --telegram 플래그 사용 시) ──
# BotFather(@BotFather)에서 발급받은 봇 토큰
# TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
# TELEGRAM_CHAT_ID=123456789

# ── 공통 설정 ───────────────────────────────────────
# 아카이브 저장 경로 (선택 — 기본값: ../../01-research/weekly/)
# ARCHIVE_DIR=/path/to/01-research/weekly
